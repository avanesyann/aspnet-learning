@model List<Expense>

<div class="container">
    <div class="row pt-4">
        <div class="col-6">
            <h2 class="text-primary">
                Expenses
            </h2>
        </div>
        <div class="col-6 text-end">
            <a asp-controller="Expense" asp-action="Create" class="btn btn-primary">
                Add a new Expense
            </a>
        </div>
    </div>

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>
                    Expense
                </th>
                <th>
                    Amount
                </th>
                <th>

                </th>
            </tr>
        </thead>

        <tbody>
            @foreach(var obj in Model.OrderByDescending(u => u.Amount))
            {
                <tr>
                    <td>@obj.Description</td>
                    <td>@obj.Amount</td>
                    <td>
                        <div class="w-75 btn-group" role="group">
                            <a asp-controller="Expense" asp-action="Edit" asp-route-id="@obj.Id" class="btn btn-primary mx-2"><i class="bi bi-pencil-square"></i> Edit</a>
                            <a asp-controller="Expense" asp-action="Delete" asp-route-id="@obj.Id" class="btn btn-danger mx-2"><i class="bi bi-trash"></i> Delete</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>